# Stellar Price Oracle — Environment Configuration
# Copy to .env and fill in your values

# === Aggregator Service ===
PORT=4000
POLLING_INTERVAL_MS=30000
STALENESS_THRESHOLD_MS=120000
WATCHED_ASSETS=XLM,USDC,BTC,ETH,USDT
LOG_LEVEL=info

# === Soroban Contract ===
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
ADMIN_SECRET_KEY=

# === Oracle Source API Keys ===
CHAINLINK_BASE_URL=https://min-api.cryptocompare.com/data
CHAINLINK_API_KEY=

REDSTONE_BASE_URL=https://api.redstone.finance

BAND_BASE_URL=https://laozi1.bandchain.org/api

REFLECTOR_BASE_URL=https://api.reflector.xyz

# === REST API ===
API_PORT=3000
WS_PORT=3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CACHE_TTL_MS=15000

# === Database (PostgreSQL) - Optional ===
DATABASE_ENABLED=false
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=stellar_oracle
DATABASE_USER=postgres
DATABASE_PASSWORD=

# === Alert Manager ===
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_RETRIES=3
ALERT_WEBHOOK_RETRY_DELAY_MS=1000
ALERT_CONSOLE_LOG=true
ALERT_FILE_LOG=true
ALERT_DEVIATION_THRESHOLD=5
ALERT_STALE_THRESHOLD=300
ALERT_SOURCE_DOWN_THRESHOLD=3

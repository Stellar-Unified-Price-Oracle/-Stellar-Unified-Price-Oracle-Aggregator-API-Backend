# Stellar Price Oracle — Environment Configuration
# Copy to .env and fill in your values

# === Aggregator Service ===
PORT=4000
POLLING_INTERVAL_MS=30000
STALENESS_THRESHOLD_MS=120000
WATCHED_ASSETS=XLM,USDC,BTC,ETH,USDT
LOG_LEVEL=info

# === Soroban Contract ===
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
ADMIN_SECRET_KEY=

# === Oracle Source API Keys ===
CHAINLINK_BASE_URL=https://min-api.cryptocompare.com/data
CHAINLINK_API_KEY=

REDSTONE_BASE_URL=https://api.redstone.finance

BAND_BASE_URL=https://laozi1.bandchain.org/api

REFLECTOR_BASE_URL=https://api.reflector.xyz

# === REST API ===
API_PORT=3000
WS_PORT=3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CACHE_TTL_MS=15000

# === Redis Cache (Optional) ===
# Leave empty to use LRU cache fallback
REDIS_URL=
PRICE_CACHE_TTL_MS=15000
HISTORY_CACHE_TTL_MS=60000
SOURCES_CACHE_TTL_MS=300000
HEALTH_CACHE_TTL_MS=30000

# === PostgreSQL / TimescaleDB Database (Optional) ===
# Leave empty to use file-based storage
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_oracle
# Issue #42 — TimescaleDB hypertable for historical price data.
# Set to "false" to keep a plain Postgres table (auto-falls back if the
# timescaledb extension is not installed).
USE_TIMESCALEDB=true
# Chunk interval in seconds for the integer `timestamp` time dimension (default 7 days).
TIMESCALE_CHUNK_INTERVAL_SECONDS=604800
# Optional automatic retention (0 = keep forever).
HISTORY_RETENTION_DAYS=0

# === SSRF Protection — Outbound Oracle Requests (Issue #39) ===
# Outbound requests are restricted to the hosts of the configured source URLs
# above. Add extra allowed hosts here (comma-separated) if needed.
ORACLE_ALLOWED_HOSTS=
# Set to "false" to disable SSRF validation (NOT recommended).
SSRF_PROTECTION_ENABLED=true
# Allow outbound requests to private/internal IPs (NOT recommended; testing only).
SSRF_ALLOW_PRIVATE_IPS=false
OUTBOUND_REQUEST_TIMEOUT_MS=10000

# === WebSocket Security (Issue #40) ===
# Comma-separated list of allowed browser Origins for WS upgrades.
# Leave empty to allow any origin that sends an Origin header.
WS_ALLOWED_ORIGINS=
# Require an Origin header on upgrade (rejects unknown non-browser clients).
WS_REQUIRE_ORIGIN=true
# Per-IP connection rate limiting for upgrade attempts.
WS_RATE_LIMIT_MAX=20
WS_RATE_LIMIT_WINDOW_MS=60000
# CSRF protection for the API WebSocket. When set, clients must fetch a token
# from GET /api/v1/ws-token and pass it as ?token=<token> on the WS URL.
WS_CSRF_SECRET=
WS_CSRF_TTL_MS=300000

# HMAC signing for WebSocket connections (Issue #35).
# When set, clients must pass ?ts=<epoch_ms>&nonce=<uuid>&sig=<hmac-sha256>
# on the WS URL. See api/src/middleware/ws-signing.ts for signing details.
WS_HMAC_SECRET=

# === Encryption at Rest (Issue #41) ===
# 32-byte key as 64 hex chars (generate with: tsx scripts/encrypt-secret.ts genkey).
# When set, sensitive env values stored as `enc:...` payloads are decrypted at
# startup, and historical price files can be encrypted at rest.
ENCRYPTION_KEY=
# During key rotation, keep the previous key here so old data still decrypts.
ENCRYPTION_KEY_PREVIOUS=
# Encrypt historical price JSON files written by the aggregator.
ENCRYPT_HISTORY=false

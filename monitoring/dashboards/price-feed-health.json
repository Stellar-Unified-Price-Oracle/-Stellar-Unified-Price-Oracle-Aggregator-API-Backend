  "liveNow": true,
  "panels": [
    {
      "id": 14,
      "title": "Last Price Update Age",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "time() - last_price_timestamp_seconds",
          "legendFormat": "{{asset}} age (s)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "Price Deviation %",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(price_deviation_percent_bucket[5m])) by (le, asset))",
          "legendFormat": "{{asset}} p95 deviation",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Active Oracle Alerts",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "stellar_oracle_alerts",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "title": "Source Health Overview",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(stellar_oracle_source_healthy)",
          "legendFormat": "avg healthy sources",
          "refId": "A"
        }
      ]
    }
  ],

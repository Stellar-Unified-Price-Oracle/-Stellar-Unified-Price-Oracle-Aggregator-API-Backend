{
  "name": "@stellar-oracle/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.ts tests/integration.test.ts",
    "test:integration:watch": "vitest --config vitest.config.integration.ts tests/integration.test.ts",
    "migrate:up": "tsx scripts/migrate.ts up",
    "migrate:down": "tsx scripts/migrate.ts down",
    "migrate:dry-run": "tsx scripts/migrate.ts up --dry-run",
    "migrate:create": "node-pg-migrate create -m migrations -j ts",
    "archive:run": "tsx scripts/archive.ts run",
    "archive:dry-run": "tsx scripts/archive.ts run --dry-run",
    "archive:restore": "tsx scripts/archive.ts restore",
    "generate:openapi": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-jaeger": "^2.9.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.17.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.1",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^10.7.0",
    "@testcontainers/redis": "^10.7.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.7.0",
    "node-fetch": "^2.7.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.10"
  }
}

{
  "name": "@stellar-oracle/client",
  "version": "1.0.0",
  "description": "TypeScript client SDK for Stellar Unified Price Oracle",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "generate:client": "openapi --input ../api/openapi.json --output ./src/generated --client fetch --name StellarOracleApiClient",
    "generate:sdks": "node scripts/generate-sdks.js"
  },
  "keywords": [
    "stellar",
    "oracle",
    "price",
    "sdk",
    "soroban",
    "websocket",
    "cryptocurrency"
  ],
  "author": "Stellar Unified Price Oracle",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stellar-Unified-Price-Oracle/-Stellar-Unified-Price-Oracle-Aggregator-API-Backend.git",
    "directory": "sdk"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "openapi-typescript-codegen": "^0.31.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
